#!/bin/bash
# pre-push hook — run the pyxen test suite before allowing any push.
# If tests fail the push is aborted.

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Resolve Python — prefer the .venv if it exists
if [ -f ".venv/bin/python" ]; then
    PYTHON=".venv/bin/python"
else
    PYTHON="python3"
fi

PYTHONPATH="src:$PYTHONPATH"
export PYTHONPATH

echo "→ updating README (primitives + extensions + examples + roadmap)..."
"$PYTHON" scripts/update-readme.py
if git diff --quiet README.md; then
    echo "  README unchanged"
else
    git add README.md
    git commit --amend --no-edit --no-verify  # skip hooks to avoid recursion
    echo "  README updated and amended into commit"
fi

echo "→ integration test staleness check..."
"$PYTHON" scripts/check-integration-staleness.py

echo "→ secrets check (LLM)..."
"$PYTHON" scripts/check-secrets.py

echo "→ coding rules check..."
"$PYTHON" scripts/check-coding-rules.py

echo "→ mypy (type checking)..."
"$PYTHON" -m mypy src examples
echo "→ pyxen test..."
"$PYTHON" -m pyxen.test
