# Service-account JSON key for the GCP project that hosts the BigQuery dataset.
# Generate this file from the GCP Console:
#
#  1. IAM & Admin → Service Accounts → select your SA → Keys → Add Key → JSON
#  2. Copy the full JSON payload here as a single line (or use gcloud):
#
#       gcloud iam service-accounts keys create sa-key.json \
#         --iam-account=sa-name@project.iam.gserviceaccount.com
#       GCP_SA_JSON=$(cat sa-key.json) && echo "GCP_SA_JSON=$GCP_SA_JSON" >> .env
#
# The key must be a single line. Most shell tools output pretty-printed JSON
# with newlines; collapse them before writing to .env.
#
# Example (truncated — replace with your real key):
GCP_SA_JSON={"type":"service_account","project_id":"my-gcp-project","private_key":"-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n","client_email":"my-sa@my-gcp-project.iam.gserviceaccount.com","client_id":"123456789","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/my-sa%40my-gcp-project.iam.gserviceaccount.com"}
