{
  "version": "1",
  "identity": {
    "implementation": "env",
    "config": {}
  },
  "tokens": {
    "implementation": "json_budget",
    "config": { "path": "./budget.json", "daily_limit": 100000 }
  },
  "ipc": {
    "implementation": "inproc",
    "config": {}
  },
  "pkg": {
    "implementation": "pip",
    "config": {
      "requirements": "requirements.txt",
      "python": "python3"
    }
  },
  "storage": {
    "implementation": "local_sqlite",
    "config": { "path": "./session_tracker.db" }
  },
  "secrets": {
    "implementation": "dotenv",
    "config": { "path": "./.env" }
  },
  "observability": {
    "implementation": "stdout",
    "config": { "level": "info" }
  },
  "cron": {
    "on_duplicate": "replace",
    "jobs": [
      {
        "name": "pyxen-demo-session-report",
        "command": "echo \"$(date -u -Iseconds) session_report: $(whoami)\" >> /tmp/pyxen-demo-sessions.log",
        "schedule": "0 * * * *"
      }
    ]
  }
}
