{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Cutuy/pyxen/schemas/runtime.schema.json",
  "title": "pyxen runtime config",
  "description": "The runtime.json manifest that maps each primitive to an implementation. Authored per-deployment; the application code never reads it directly.",
  "type": "object",
  "required": ["version"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+$",
      "description": "Manifest format version (integer string)."
    },
    "identity":        { "$ref": "#/$defs/primitive" },
    "tokens":          { "$ref": "#/$defs/primitive" },
    "ipc":             { "$ref": "#/$defs/primitive" },
    "pkg":             { "$ref": "#/$defs/primitive" },
    "storage":         { "$ref": "#/$defs/primitive" },
    "secrets":         { "$ref": "#/$defs/primitive" },
    "observability":   { "$ref": "#/$defs/primitive" },
    "cron": {
      "type": "object",
      "properties": {
        "on_duplicate": {
          "type": "string",
          "enum": ["replace", "fail"],
          "description": "Behavior when a job name already exists. 'replace' overwrites (default), 'fail' raises an error.",
          "default": "replace"
        },
        "jobs": {
          "type": "array",
          "description": "Cron jobs to auto-schedule on runtime load.",
          "items": {
            "type": "object",
            "required": ["name", "command", "schedule"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique job name."
              },
              "command": {
                "type": "string",
                "description": "Command or script to execute."
              },
              "schedule": {
                "type": "string",
                "description": "Cron expression (5-field or @-shorthand)."
              },
              "enabled": {
                "type": "boolean",
                "description": "Whether the job is enabled on startup.",
                "default": true
              },
              "environment": {
                "type": "object",
                "description": "Environment variables for the job.",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "primitive": {
      "type": "object",
      "required": ["implementation"],
      "additionalProperties": false,
      "properties": {
        "implementation": {
          "type": "string",
          "description": "Module name under pyxen.impl.<primitive>. E.g., 'local_sqlite' resolves to pyxen.impl.storage.local_sqlite."
        },
        "config": {
          "type": "object",
          "description": "Implementation-specific config object. The schema is intentionally permissive; each impl validates its own config."
        }
      }
    }
  }
}
