# API key for the pre-push hook LLM feature.
# The update-readme script uses this to call DeepSeek's OpenAI-compatible API
# and auto-update the roadmap / TODOs section of README.md.
#
# Copy this to .env (which is gitignored) and fill in your key:
#   cp .env.example .env
#   (edit .env with your key)
#
DEEPSEEK_API_KEY=***
